# ✅ Weekly Status Preview Function

```javascript
function renderWeeklyStatusPreview(data) {
  var html = '';

  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">WEEKLY STATUS REPORT</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.client_name || '') + '</div>';
  html += '<div class="doc-cover-credit">Week Ending: ' + escHtml(data.week_ending || '') + '</div>';
  html += '</div>';

  if (data.sprint_metrics?.length) {
    html += '<div class="doc-section-title">Sprint Metrics</div>';
    html += '<table class="doc-table"><thead><tr><th>Metric</th><th>Planned</th><th>Actual</th><th>Status</th></tr></thead><tbody>';

    data.sprint_metrics.forEach(function(m){
      html += '<tr><td>' + escHtml(m.metric || '') + '</td>' +
              '<td>' + escHtml(m.planned || '') + '</td>' +
              '<td>' + escHtml(m.actual || '') + '</td>' +
              '<td>' + escHtml(m.status || '') + '</td></tr>';
    });

    html += '</tbody></table>';
  }

  return html;
}
```

