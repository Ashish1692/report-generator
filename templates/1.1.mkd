# ✅ PIR Preview Function

```javascript
function renderPIRPreview(data) {
  var html = '';

  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">POST INCIDENT REVIEW</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.incident_number || '') + '</div>';
  html += '<div class="doc-cover-credit">Priority: ' + escHtml(data.priority || '') + '</div>';
  html += '</div>';

  if (data.short_description) {
    html += '<div class="doc-text"><strong>Description:</strong> ' +
      escHtml(data.short_description) + '</div>';
  }

  if (data.timeline_events?.length) {
    html += '<div class="doc-section-title">Timeline</div>';
    html += '<table class="doc-table"><thead><tr><th>Time</th><th>Event</th><th>Description</th></tr></thead><tbody>';

    data.timeline_events.forEach(function(t){
      html += '<tr><td>' + escHtml(t.time || '') + '</td>' +
              '<td>' + escHtml(t.event || '') + '</td>' +
              '<td>' + escHtml(t.description || '') + '</td></tr>';
    });

    html += '</tbody></table>';
  }

  return html;
}
```

