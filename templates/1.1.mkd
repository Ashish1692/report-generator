# ✅ Release Notes Preview Function

```javascript
function renderReleaseNotesPreview(data) {
  var html = '';

  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">RELEASE NOTES</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.application || '') + '</div>';
  html += '<div class="doc-cover-credit">Version: ' + escHtml(data.release_version || '') + '</div>';
  html += '</div>';

  if (data.enhancements?.length) {
    html += '<div class="doc-section-title">Enhancements</div>';
    html += '<table class="doc-table"><thead><tr><th>Feature</th><th>Description</th><th>Impact</th></tr></thead><tbody>';

    data.enhancements.forEach(function(e){
      html += '<tr><td><strong>' + escHtml(e.feature || '') + '</strong></td>' +
              '<td>' + escHtml(e.description || '') + '</td>' +
              '<td>' + escHtml(e.impact || '') + '</td></tr>';
    });

    html += '</tbody></table>';
  }

  return html;
}
```

