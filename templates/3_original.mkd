```js
async function generateIntegrationSpecification(data) {
  const { Document, Packer, Table, TableRow, WidthType } = getDocx();
  const { C, para, h1, h2, bullets, hdrCell, dataCell, statusCell, codePara } = makeDocHelpers();

  const name = safeStr(data.integration_name || "Integration Specification");
  const createdDate = safeStr(data.created_date || new Date().toLocaleDateString());
  const author = safeStr(data.author || "Author");

  const systems = data.systems || {};
  const envs = data.environments || [];
  const auth = data.authentication || {};
  const endpoints = data.endpoints || [];
  const mapping = data.field_mapping || [];
  const errors = data.error_handling || [];
  const retry = data.retry_strategy || {};

  const children = [
    h1(`${name} - Integration Specification`),
    para(`Version: ${safeStr(data.version || "")}`, false, C.GRAY, 18),
    para(`Created: ${createdDate}`, false, C.GRAY, 18),
    para(`Author: ${author}`, false, C.GRAY, 18),
    para("")
  ];

  children.push(h2("Overview"));
  children.push(...bullets([
    `Direction: ${safeStr(data.direction)}`,
    `Source System: ${safeStr(systems.source)}`,
    `Target System: ${safeStr(systems.target)}`
  ].filter(Boolean)));

  if (envs.length) {
    children.push(para(""), h2("Environments"), ...bullets(envs));
  }

  children.push(para(""), h2("Authentication"));
  children.push(...bullets([
    `Method: ${safeStr(auth.method)}`,
    safeStr(auth.details)
  ].filter(Boolean)));

  if (endpoints.length) {
    children.push(para(""), h2("Endpoints"));
    children.push(new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [2200, 1200, 3600, 2360],
      rows: [
        new TableRow({ children: [hdrCell("Name", 2200), hdrCell("Method", 1200), hdrCell("URL", 3600), hdrCell("Purpose", 2360)] }),
        ...endpoints.map((e, i) => new TableRow({
          children: [
            dataCell(e.name || "", 2200, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(e.method || "", 1200, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(e.url || "", 3600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(e.purpose || "", 2360, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    }));
  }

  if (mapping.length) {
    children.push(para(""), h2("Field Mapping"));
    children.push(new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [2800, 2800, 2000, 1760],
      rows: [
        new TableRow({ children: [hdrCell("Source Field", 2800), hdrCell("Target Field", 2800), hdrCell("Transform", 2000), hdrCell("Notes", 1760)] }),
        ...mapping.map((m, i) => new TableRow({
          children: [
            dataCell(m.source_field || "", 2800, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(m.target_field || "", 2800, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(m.transform || "", 2000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(m.notes || "", 1760, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    }));
  }

  if (errors.length) {
    children.push(para(""), h2("Error Handling"));
    children.push(new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [2600, 3600, 3160],
      rows: [
        new TableRow({ children: [hdrCell("Scenario", 2600), hdrCell("Behavior", 3600), hdrCell("Owner Action", 3160)] }),
        ...errors.map((e, i) => new TableRow({
          children: [
            dataCell(e.scenario || "", 2600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(e.behavior || "", 3600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(e.owner_action || "", 3160, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    }));
  }

  children.push(para(""), h2("Retry / Rate Limits / Monitoring"));
  children.push(...bullets([
    retry.retries != null ? `Retries: ${safeStr(retry.retries)}` : "",
    retry.backoff ? `Backoff: ${safeStr(retry.backoff)}` : "",
    retry.dead_letter ? `Dead Letter: ${safeStr(retry.dead_letter)}` : "",
    data.rate_limits ? `Rate Limits: ${safeStr(data.rate_limits)}` : ""
  ].filter(Boolean)));

  if (Array.isArray(data.logging_monitoring) && data.logging_monitoring.length) {
    children.push(para("Logging & Monitoring:", true));
    children.push(...bullets(data.logging_monitoring));
  }

  if (data.sample_request) {
    children.push(para(""), h2("Sample Request"), codePara(safeStr(data.sample_request)));
  }
  if (data.sample_response) {
    children.push(para(""), h2("Sample Response"), codePara(safeStr(data.sample_response)));
  }

  const doc = new Document({ sections: [{ properties: {}, children }] });
  const blob = await Packer.toBlob(doc);
  return { blob, filename: `${name}_Integration_Spec.docx`.replace(/[^a-z0-9._-]/gi, "_") };
}
