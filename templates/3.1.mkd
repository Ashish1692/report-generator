# ✅ 5️⃣ Add Preview Functions  
(Add after existing preview functions)

---

## ✅ MI Communications Preview

```javascript
function renderMICommsPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">MAJOR INCIDENT COMMUNICATIONS</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.major_incident_number || '') + '</div>';
  html += '</div>';

  if (data.title) {
    html += '<div class="doc-text"><strong>Title:</strong> ' +
      escHtml(data.title) + '</div>';
  }

  if (data.updates?.length) {
    html += '<div class="doc-section-title">Updates</div><ul>';
    data.updates.forEach(function(u){
      html += '<li><strong>' + escHtml(u.time || '') +
              '</strong> - ' + escHtml(u.message || '') + '</li>';
    });
    html += '</ul>';
  }

  return html;
}
```

---

## ✅ Weekly Ops Preview

```javascript
function renderWeeklyOpsPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">WEEKLY OPERATIONS REPORT</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.client_name || '') + '</div>';
  html += '</div>';

  if (data.executive_summary) {
    html += '<div class="doc-section-title">Executive Summary</div>';
    html += '<div class="doc-text">' + escHtml(data.executive_summary) + '</div>';
  }

  if (data.kpis?.length) {
    html += '<div class="doc-section-title">KPIs</div><ul>';
    data.kpis.forEach(function(k){
      html += '<li>' + escHtml(k.metric || '') + ': ' +
              escHtml(k.current || '') + '</li>';
    });
    html += '</ul>';
  }

  return html;
}
```

