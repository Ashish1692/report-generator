# ✅ Deployment Runbook Preview

```javascript
function renderDeploymentRunbookPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">DEPLOYMENT RUNBOOK</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.runbook_title || '') + '</div>';
  html += '</div>';

  if (data.execution_steps?.length) {
    html += '<div class="doc-section-title">Execution Steps</div>';
    html += '<ol>';

    data.execution_steps.forEach(function(s){
      html += '<li><strong>' + escHtml(s.action || '') + '</strong></li>';
    });

    html += '</ol>';
  }

  return html;
}
```

