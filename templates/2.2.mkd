# ✅ Incident Resolution Preview

```javascript
function renderIncidentResolutionPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">INCIDENT RESOLUTION SUMMARY</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.incident_number || '') + '</div>';
  html += '</div>';

  if (data.short_description) {
    html += '<div class="doc-text"><strong>Description:</strong> ' +
      escHtml(data.short_description) + '</div>';
  }

  if (data.symptoms?.length) {
    html += '<div class="doc-section-title">Symptoms</div><ul>';
    data.symptoms.forEach(function(s){
      html += '<li>' + escHtml(s) + '</li>';
    });
    html += '</ul>';
  }

  if (data.resolution?.summary) {
    html += '<div class="doc-section-title">Resolution</div>';
    html += '<div class="doc-text">' + escHtml(data.resolution.summary) + '</div>';
  }

  return html;
}
```

