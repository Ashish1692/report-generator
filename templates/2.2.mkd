# ✅ PIR / RCA Preview

```javascript
function renderPIRRCAPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">POST INCIDENT REVIEW (RCA)</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.incident_number || '') + '</div>';
  html += '</div>';

  if (data.executive_summary) {
    html += '<div class="doc-section-title">Executive Summary</div>';
    html += '<div class="doc-text">' + escHtml(data.executive_summary) + '</div>';
  }

  if (data.timeline?.length) {
    html += '<div class="doc-section-title">Timeline</div>';
    html += '<table class="doc-table"><thead><tr><th>Time</th><th>Event</th><th>Owner</th></tr></thead><tbody>';

    data.timeline.forEach(function(t){
      html += '<tr><td>' + escHtml(t.time || '') + '</td>' +
              '<td>' + escHtml(t.event || '') + '</td>' +
              '<td>' + escHtml(t.owner || '') + '</td></tr>';
    });

    html += '</tbody></table>';
  }

  return html;
}
```

