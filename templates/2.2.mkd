# ✅ Technical Design Preview

```javascript
function renderTechnicalDesignPreview(data) {

  var html = '';
  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">TECHNICAL DESIGN</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.story_id || '') + '</div>';
  html += '</div>';

  if (data.summary) {
    html += '<div class="doc-section-title">Summary</div>';
    html += '<div class="doc-text">' + escHtml(data.summary) + '</div>';
  }

  if (data.data_model_changes?.length) {
    html += '<div class="doc-section-title">Data Model Changes</div>';
    html += '<ul>';
    data.data_model_changes.forEach(function(d){
      html += '<li><strong>' + escHtml(d.table || '') + '</strong> - ' +
              escHtml(d.change || '') + '</li>';
    });
    html += '</ul>';
  }

  return html;
}
```

