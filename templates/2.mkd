            dataCell(x.details || '', 4760, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(dmTable);
  }

  if (comps.length) {
    children.push(para(''), h2('Implementation Components'));
    const compTable = new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [1600, 2600, 5160],
      rows: [
        new TableRow({ children: [hdrCell('Type', 1600), hdrCell('Name', 2600), hdrCell('Description', 5160)] }),
        ...comps.map((x, i) => new TableRow({
          children: [
            dataCell(x.type || '', 1600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
