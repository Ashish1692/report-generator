            dataCell(x.description || '', 5160, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(compTable);
  }

  if (sec.length) {
    children.push(para(''), h2('Security'), ...bullets(sec.map(s => `${safeStr(s.item)}: ${safeStr(s.details)}`)));
  }

  if (ints.length) {
    children.push(para(''), h2('Integrations'), ...bullets(ints.map(x => `${safeStr(x.system)}: ${safeStr(x.details)}`)));
  }

  if (tests.length) {
    children.push(para(''), h2('Testing Plan'));
    const tcTable = new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [1200, 4200, 3960],
      rows: [
        new TableRow({ children: [hdrCell('ID', 1200), hdrCell('Scenario', 4200), hdrCell('Expected', 3960)] }),
        ...tests.map((t, i) => new TableRow({
          children: [
            dataCell(t.id || '', 1200, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(t.scenario || '', 4200, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(t.expected || '', 3960, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(tcTable);
  }

  if (Array.isArray(data.deployment_notes) && data.deployment_notes.length) {
