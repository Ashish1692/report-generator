            dataCell(s.step_no != null ? String(s.step_no) : String(i + 1), 600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.action || '', 2900, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.command || '', 2500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.expected_result || '', 1700, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell([s.validation, s.stop_go].filter(Boolean).join(' | '), 1660, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(stepsTable);
  }

  if (Array.isArray(data.post_checks) && data.post_checks.length) {
    children.push(para(''), h2('Post-Checks'), ...bullets(data.post_checks));
  }
  if (Array.isArray(data.monitoring) && data.monitoring.length) {
    children.push(para(''), h2('Monitoring'), ...bullets(data.monitoring));
  }

  if (rollback.length) {
    children.push(para(''), h2('Rollback Steps'));
    const rbTable = new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [600, 3600, 2800, 2360],
      rows: [
        new TableRow({ children: [hdrCell('#', 600), hdrCell('Action', 3600), hdrCell('Command', 2800), hdrCell('Validation', 2360)] }),
        ...rollback.map((s, i) => new TableRow({
          children: [
            dataCell(s.step_no != null ? String(s.step_no) : String(i + 1), 600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.action || '', 3600, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.command || '', 2800, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.validation || '', 2360, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(rbTable);
  }

  if (Array.isArray(data.contacts) && data.contacts.length) {
    children.push(para(''), h2('Contacts'), ...bullets(data.contacts.map(c => `${safeStr(c.role)} - ${safeStr(c.name)} (${safeStr(c.contact)})`)));
  }

  const doc = new Document({ sections: [{ properties: {}, children }] });
  const blob = await Packer.toBlob(doc);
  return { blob, filename: `${title}_Runbook.docx`.replace(/[^a-z0-9._-]/gi, '_') };
}


// ── (7) User Story Technical Design ────────────────────────────────────────
async function generateUserStoryTechnicalDesign(data) {
  const { Document, Packer, Table, TableRow, WidthType } = getDocx();
