# JavaScript mapping (DOCX generators)

> Add these to your `main.js` after existing generators. Assumes you already have: `getDocx()`, `docxColors()`, `safeStr()` like your reference.

```js
// ── Shared Helpers (re-use across templates) ───────────────────────────────
function makeDocHelpers() {
  const { Paragraph, TextRun, TableCell, AlignmentType, BorderStyle, WidthType, ShadingType } = getDocx();
  const C = docxColors();

  const bdr = { style: BorderStyle.SINGLE, size: 1, color: C.MGRAY };
  const borders = { top: bdr, bottom: bdr, left: bdr, right: bdr };

  function para(t, bold, color, size) {
    return new Paragraph({
      spacing: { before: 60, after: 60 },
      children: [new TextRun({ text: safeStr(t), bold: !!bold, color: color || C.GRAY, size: size || 20, font: 'Arial' })]
    });
  }

  function h1(t) {
    return new Paragraph({
      spacing: { before: 120, after: 120 },
      children: [new TextRun({ text: safeStr(t), bold: true, color: C.NAVY, size: 32, font: 'Arial' })]
    });
  }

  function h2(t) {
    return new Paragraph({
      spacing: { before: 240, after: 120 },
      children: [new TextRun({ text: safeStr(t), bold: true, color: C.BLUE, size: 28, font: 'Arial' })]
    });
  }

  function bullets(arr) {
    const items = Array.isArray(arr) ? arr : [];
    return items
      .filter(x => safeStr(x).trim().length > 0)
      .map(x => new Paragraph({
        spacing: { before: 20, after: 20 },
        bullet: { level: 0 },
        children: [new TextRun({ text: safeStr(x), color: C.GRAY, size: 20, font: 'Arial' })]
      }));
  }

  function hdrCell(t, w) {
    return new TableCell({
      borders,
      width: { size: w, type: WidthType.DXA },
      shading: { fill: C.BLUE, type: ShadingType.CLEAR },
      margins: { top: 80, bottom: 80, left: 120, right: 120 },
      children: [new Paragraph({ children: [new TextRun({ text: safeStr(t), bold: true, color: C.WHITE, size: 18, font: 'Arial' })] })]
    });
  }

  function dataCell(t, w, bg) {
    return new TableCell({
      borders,
      width: { size: w, type: WidthType.DXA },
      shading: { fill: bg || C.WHITE, type: ShadingType.CLEAR },
      margins: { top: 70, bottom: 70, left: 120, right: 120 },
      children: [new Paragraph({ children: [new TextRun({ text: safeStr(t), color: C.GRAY, size: 18, font: 'Arial' })] })]
    });
  }

  function statusCell(t, w) {
    const s = (t || '').toLowerCase();
    let bg, tc;
    if (s.includes('completed') || s.includes('done') || s.includes('on track')) { bg = C.LIGHT_GREEN; tc = C.GREEN; }
    else if (s.includes('in progress') || s.includes('ongoing') || s.includes('pending')) { bg = C.LIGHT_BLUE; tc = C.BLUE; }
    else if (s.includes('behind') || s.includes('delayed') || s.includes('blocked')) { bg = C.LIGHT_AMBER; tc = C.AMBER; }
    else { bg = C.LIGHT_GRAY; tc = C.GRAY; }

    return new TableCell({
      borders,
      width: { size: w, type: WidthType.DXA },
      shading: { fill: bg, type: ShadingType.CLEAR },
      margins: { top: 70, bottom: 70, left: 120, right: 120 },
      children: [new Paragraph({ children: [new TextRun({ text: safeStr(t), bold: true, color: tc, size: 18, font: 'Arial' })] })]
    });
  }

  return { C, para, h1, h2, bullets, hdrCell, dataCell, statusCell };
}


// ── (1) Incident Resolution Summary ────────────────────────────────────────
async function generateIncidentResolutionSummary(data) {
  const { Document, Packer, Table, TableRow, WidthType } = getDocx();
  const { C, para, h1, h2, bullets, hdrCell, dataCell, statusCell } = makeDocHelpers();

  const inc = safeStr(data.incident_number || 'INC');
  const title = inc + ' - Incident Resolution Summary';
  const createdDate = safeStr(data.created_date || new Date().toLocaleDateString());
  const author = safeStr(data.author || 'Author');

  const impact = data.impact || {};
  const symptoms = data.symptoms || [];
  const res = data.resolution || {};
  const resSteps = data.resolution_steps || [];
  const nextSteps = data.next_steps || [];
  const rel = data.related_records || {};

  const children = [
    h1(title),
    para(`Created: ${createdDate}`, false, C.GRAY, 18),
    para(`Author: ${author}`, false, C.GRAY, 18),
    para(''),

    h2('Incident Details')
  ];

  const detailsTable = new Table({
    width: { size: 9360, type: WidthType.DXA },
    columnWidths: [2500, 6860],
    rows: [
      new TableRow({ children: [hdrCell('Field', 2500), hdrCell('Value', 6860)] }),
      new TableRow({ children: [dataCell('Short Description', 2500), dataCell(data.short_description || '', 6860)] }),
      new TableRow({ children: [dataCell('Priority', 2500), statusCell(data.priority || '', 6860)] }),
      new TableRow({ children: [dataCell('Service', 2500), dataCell(data.service || '', 6860)] }),
      new TableRow({ children: [dataCell('Assignment Group', 2500), dataCell(data.assignment_group || '', 6860)] }),
      new TableRow({ children: [dataCell('Opened At', 2500), dataCell(data.opened_at || '', 6860)] }),
      new TableRow({ children: [dataCell('Resolved At', 2500), dataCell(data.resolved_at || '', 6860)] })
    ]
  });
  children.push(detailsTable, para(''));

  children.push(h2('Impact'));
  children.push(...bullets([
    `Impact Window: ${safeStr(impact.impact_start)} → ${safeStr(impact.impact_end)}`.trim(),
    `Affected Users: ${safeStr(impact.affected_users)}`,
    `Customer Visible: ${safeStr(impact.customer_visible)}`,
    `Business Impact: ${safeStr(impact.business_impact)}`
  ]));

  if (symptoms.length) {
    children.push(para(''), h2('Symptoms Observed'), ...bullets(symptoms));
  }

  children.push(para(''), h2('Resolution'));
  children.push(...bullets([
    `Summary: ${safeStr(res.summary)}`,
    res.root_cause_if_known ? `Root Cause (if known): ${safeStr(res.root_cause_if_known)}` : '',
    res.workaround ? `Workaround: ${safeStr(res.workaround)}` : ''
  ].filter(Boolean)));

  if (resSteps.length) {
    children.push(para(''), h2('Resolution Steps'));
    const stepsTable = new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [800, 6160, 2400],
      rows: [
        new TableRow({ children: [hdrCell('#', 800), hdrCell('Step', 6160), hdrCell('Owner', 2400)] }),
        ...resSteps.map((s, i) => new TableRow({
          children: [
            dataCell(String(i + 1), 800, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.step || '', 6160, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(s.owner || '', 2400, i % 2 ? C.LIGHT_GRAY : C.WHITE)
          ]
        }))
      ]
    });
    children.push(stepsTable);
  }

  if (nextSteps.length) {
    children.push(para(''), h2('Next Steps / Actions'));
    const actionsTable = new Table({
      width: { size: 9360, type: WidthType.DXA },
      columnWidths: [5000, 1800, 1400, 1160],
      rows: [
        new TableRow({ children: [hdrCell('Action', 5000), hdrCell('Owner', 1800), hdrCell('Due Date', 1400), hdrCell('Status', 1160)] }),
        ...nextSteps.map((a, i) => new TableRow({
          children: [
            dataCell(a.action || '', 5000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(a.owner || '', 1800, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            dataCell(a.due_date || '', 1400, i % 2 ? C.LIGHT_GRAY : C.WHITE),
            statusCell(a.status || '', 1160)
          ]
        }))
      ]
    });
    children.push(actionsTable);
  }

  children.push(para(''), h2('Related Records'));
  children.push(...bullets([
    rel.problem ? `Problem: ${safeStr(rel.problem)}` : '',
    rel.change ? `Change: ${safeStr(rel.change)}` : '',
    rel.kb ? `Knowledge: ${safeStr(rel.kb)}` : ''
  ].filter(Boolean)));

  const doc = new Document({ sections: [{ properties: {}, children }] });
  const blob = await Packer.toBlob(doc);
  return { blob, filename: `${inc}_Incident_Resolution_Summary.docx`.replace(/[^a-z0-9._-]/gi, '_') };
}


