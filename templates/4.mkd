# ✅ 7️⃣ Preview Function

```javascript
function renderTechnicalDocPreview(data) {

  var html = '';

  html += '<div class="doc-cover">';
  html += '<div class="doc-cover-title">TECHNICAL IMPLEMENTATION DOCUMENT</div>';
  html += '<div class="doc-cover-sub">' + escHtml(data.document_title || '') + '</div>';
  html += '</div>';

  if (data.summary) {
    html += '<div class="doc-section-title">Summary</div>';
    html += '<div class="doc-text">' + escHtml(data.summary) + '</div>';
  }

  if (data.step_by_step_guide?.length) {
    html += '<div class="doc-section-title">Implementation Steps</div><ol>';
    data.step_by_step_guide.forEach(function(s){
      html += '<li>' + escHtml(s) + '</li>';
    });
    html += '</ol>';
  }

  if (data.testing_validation?.length) {
    html += '<div class="doc-section-title">Testing</div><ul>';
    data.testing_validation.forEach(function(t){
      html += '<li>' + escHtml(t.test_case || '') +
              ' - <strong>' + escHtml(t.status || '') + '</strong></li>';
    });
    html += '</ul>';
  }

  return html;
}
```

