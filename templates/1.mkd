Great choices. These three templates will cover your most critical workflows as a ServiceNow Consultant: reactive incidents (PIR), proactive deployments (Release Notes), and ongoing communication (Weekly Status). 

Since the `docx` helper functions (`para`, `h1`, `h2`, `hdrCell`, `dataCell`, `statusCell`) from your original code are perfectly reusable, I have focused the JavaScript implementations below strictly on the extraction and table-building logic. You can drop these directly into your `main.js` file alongside your existing generator.

---

### 1. Major Incident Report (PIR)

This structure captures the timeline of the outage, the technical root cause, and the follow-up tasks required to prevent recurrence.

#### JSON Structure
```json
{
  "incident_number": "INC0923847",
  "priority": "P1 - Critical",
  "short_description": "Database cluster failover failure in US-East",
  "assignment_group": "Database Admins",
  "timeline_events": [
    { "time": "08:15 AM", "event": "Alert Triggered", "description": "High CPU utilization on Node 1" },
    { "time": "08:30 AM", "event": "Bridge Opened", "description": "Major Incident bridge engaged" },
    { "time": "09:45 AM", "event": "Resolution", "description": "Manual failover completed to Node 2" }
  ],
  "root_cause_analysis": [
    { "component": "Automated Failover Script", "issue": "Timeout threshold too low", "fix": "Increased threshold from 30s to 120s" }
  ],
  "preventive_actions": [
    { "action": "Audit all cluster timeout settings", "owner": "DBA Team", "status": "In Progress" },
    { "action": "Update runbook for manual failover", "owner": "Major Incident Management", "status": "Pending" }
  ]
}
```

#### JavaScript Implementation
```javascript
async function generatePIR(data) {
    const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell, WidthType, ShadingType, BorderStyle } = getDocx();
    const C = docxColors();
    
    // [Insert your existing helper functions here: bdr, borders, para, h1, h2, hdrCell, dataCell, statusCell]

    const headerChildren = [
        h1('Post-Incident Review: ' + safeStr(data.incident_number)),
        para('Priority: ' + safeStr(data.priority), true, C.NAVY, 20),
        para('Description: ' + safeStr(data.short_description), false, C.GRAY, 18),
        para('Assignment Group: ' + safeStr(data.assignment_group), false, C.GRAY, 18),
        para('')
    ];

    if (data.timeline_events?.length > 0) {
        headerChildren.push(h2('Incident Timeline'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [1500, 2500, 5360],
            rows: [
                new TableRow({ children: [hdrCell('Time', 1500), hdrCell('Event', 2500), hdrCell('Description', 5360)] }),
                ...data.timeline_events.map((t, i) => new TableRow({
                    children: [
                        dataCell(t.time || '', 1500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(t.event || '', 2500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(t.description || '', 5360, i % 2 ? C.LIGHT_GRAY : C.WHITE)
                    ]
                }))
            ]
        }));
        headerChildren.push(para(''));
    }

    if (data.root_cause_analysis?.length > 0) {
        headerChildren.push(h2('Root Cause Analysis'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [2000, 3680, 3680],
            rows: [
                new TableRow({ children: [hdrCell('Component', 2000), hdrCell('Issue', 3680), hdrCell('Fix Applied', 3680)] }),
                ...data.root_cause_analysis.map((r, i) => new TableRow({
                    children: [
                        dataCell(r.component || '', 2000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(r.issue || '', 3680, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(r.fix || '', 3680, i % 2 ? C.LIGHT_GRAY : C.WHITE)
                    ]
                }))
            ]
        }));
        headerChildren.push(para(''));
    }

    if (data.preventive_actions?.length > 0) {
        headerChildren.push(h2('Preventive Actions'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [5000, 2560, 1800],
            rows: [
                new TableRow({ children: [hdrCell('Action', 5000), hdrCell('Owner', 2560), hdrCell('Status', 1800)] }),
                ...data.preventive_actions.map((p, i) => new TableRow({
                    children: [
                        dataCell(p.action || '', 5000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(p.owner || '', 2560, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        statusCell(p.status || '', 1800) // Reusing your color-coded status cell
                    ]
                }))
            ]
        }));
    }

    const doc = new Document({ sections: [{ properties: {}, children: headerChildren }] });
    return { blob: await Packer.toBlob(doc), filename: `${data.incident_number}_PIR.docx` };
}
```

