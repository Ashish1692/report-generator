### 4. Consultant Weekly Status & Sprint Report

This tracks your velocity, closed items, and any roadblocks requiring client intervention.

#### JSON Structure
```json
{
  "consultant_name": "Jane Doe",
  "client_name": "Acme Corp",
  "week_ending": "April 26, 2024",
  "sprint_metrics": [
    { "metric": "Story Points", "planned": "35", "actual": "32", "status": "On Track" },
    { "metric": "Hours Logged", "planned": "40", "actual": "42", "status": "Completed" }
  ],
  "completed_tickets": [
    { "ticket": "STRY001928", "type": "Story", "description": "Build Inbound Email Action for HR Cases" },
    { "ticket": "INC092837", "type": "Defect", "description": "Fix ACLs on cmdb_ci_server table" }
  ],
  "current_blockers": [
    { "blocker": "Waiting on API credentials for Workday integration", "impact": "High", "dependency": "Client Security Team" }
  ]
}
```

#### JavaScript Implementation
```javascript
async function generateWeeklyStatus(data) {
    const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell, WidthType, ShadingType, BorderStyle } = getDocx();
    const C = docxColors();
    
    // [Insert your existing helper functions here]

    const headerChildren = [
        h1('Weekly Status Report'),
        para('Consultant: ' + safeStr(data.consultant_name), false, C.GRAY, 18),
        para('Client: ' + safeStr(data.client_name), false, C.GRAY, 18),
        para('Week Ending: ' + safeStr(data.week_ending), true, C.NAVY, 18),
        para('')
    ];

    if (data.sprint_metrics?.length > 0) {
        headerChildren.push(h2('Sprint Velocity'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [3000, 1500, 1500, 3360],
            rows: [
                new TableRow({ children: [hdrCell('Metric', 3000), hdrCell('Planned', 1500), hdrCell('Actual', 1500), hdrCell('Status', 3360)] }),
                ...data.sprint_metrics.map((m, i) => new TableRow({
                    children: [
                        dataCell(m.metric || '', 3000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(m.planned || '', 1500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(m.actual || '', 1500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        statusCell(m.status || '', 3360)
                    ]
                }))
            ]
        }));
        headerChildren.push(para(''));
    }

    if (data.completed_tickets?.length > 0) {
        headerChildren.push(h2('Items Completed This Week'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [1500, 1500, 6360],
            rows: [
                new TableRow({ children: [hdrCell('Ticket', 1500), hdrCell('Type', 1500), hdrCell('Description', 6360)] }),
                ...data.completed_tickets.map((c, i) => new TableRow({
                    children: [
                        dataCell(c.ticket || '', 1500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(c.type || '', 1500, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        dataCell(c.description || '', 6360, i % 2 ? C.LIGHT_GRAY : C.WHITE)
                    ]
                }))
            ]
        }));
        headerChildren.push(para(''));
    }

    if (data.current_blockers?.length > 0) {
        headerChildren.push(h2('Risks & Blockers'));
        headerChildren.push(new Table({
            width: { size: 9360, type: WidthType.DXA },
            columnWidths: [4000, 1500, 3860],
            rows: [
                new TableRow({ children: [hdrCell('Blocker', 4000), hdrCell('Impact', 1500), hdrCell('Dependency', 3860)] }),
                ...data.current_blockers.map((b, i) => new TableRow({
                    children: [
                        dataCell(b.blocker || '', 4000, i % 2 ? C.LIGHT_GRAY : C.WHITE),
                        statusCell(b.impact || '', 1500), // Leveraging status color logic
                        dataCell(b.dependency || '', 3860, i % 2 ? C.LIGHT_GRAY : C.WHITE)
                    ]
                }))
            ]
        }));
    }

    const doc = new Document({ sections: [{ properties: {}, children: headerChildren }] });
    return { blob: await Packer.toBlob(doc), filename: `Weekly_Status_${data.week_ending.replace(/[^a-z0-9]/gi, '_')}.docx` };
}
